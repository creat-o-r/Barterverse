# Test environment configuration for Firebase emulators
NODE_ENV=test
NEXT_PUBLIC_ENVIRONMENT=test
NEXT_PUBLIC_FIREBASE_ENV=development

# Firebase emulator configuration
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-barterverse
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-barterverse.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-barterverse.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:demo

# Emulator hosts
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# AI API Key (placeholder for testing)
GOOGLE_API_KEY=test-key