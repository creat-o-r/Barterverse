# Environment variables template
# Copy this file to create your .env files (.env.development, .env.production, etc.)
# DO NOT commit actual API keys to the repository

# Google API Key (get from Google Cloud Console)
GOOGLE_API_KEY=your_google_api_key_here

# Firebase Configuration (get from Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Environment-specific settings
FIREBASE_ENV=development
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true

# Firebase Emulator Hosts (for local development)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199