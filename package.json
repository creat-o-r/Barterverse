{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "build:ai": "tsc -p tsconfig.ai.json",
    "genkit:dev": "npm run build:ai && genkit start -- node build/ai/dev.js",
    "genkit:watch": "nodemon --watch src/ai --ext ts --exec \"npm run build:ai && genkit start -- node build/ai/dev.js\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "issues:report": "node scripts/github-issues-workflow.js report",
    "issues:create": "node scripts/github-issues-workflow.js create",
    "issues:update": "node scripts/github-issues-workflow.js update",
    "issues:start": "node scripts/github-issues-workflow.js start",
    "issues:progress": "node scripts/github-issues-workflow.js progress",
    "issues:auto": "node scripts/github-issues-workflow.js auto",
    "claude:info": "node scripts/claude-context-helper.js info",
    "claude:title": "node scripts/claude-context-helper.js title",
    "claude:setup": "node scripts/claude-context-helper.js setup",
    "projects:create-item-matching": "node scripts/github-projects-integration.js create-item-matching",
    "projects:create-firebase-ai": "node scripts/github-projects-integration.js create-firebase-ai",
    "projects:status": "node scripts/github-projects-integration.js status",
    "projects:link": "node scripts/github-projects-integration.js link",
    "jules:detect": "node scripts/jules-branch-integration.js detect",
    "jules:auto": "node scripts/jules-branch-integration.js auto",
    "jules:integrate": "node scripts/jules-branch-integration.js integrate",
    "jules:check-orphans": "node scripts/jules-branch-integration.js check-orphans",
    "jules:cleanup": "node scripts/jules-branch-integration.js cleanup",
    "firebase:seed": "node scripts/seed-firestore.js",
    "firebase:seed-emulator": "node scripts/seed-emulator.js",
    "firebase:emulators": "firebase emulators:start --project demo-project",
    "firebase:emulators:start": "firebase emulators:start --project demo-project",
    "firebase:emulators:exec": "firebase emulators:exec --project demo-project",
    "firebase:deploy": "firebase deploy --project barterverse-l9uq3",
    "firebase:config": "node scripts/load-firebase-config.js",
    "firebase:config:dev": "node scripts/load-firebase-config.js development",
    "firebase:config:preview": "node scripts/load-firebase-config.js preview",
    "firebase:config:production": "node scripts/load-firebase-config.js production",
    "test:emulators": "firebase emulators:exec --project demo-project \"npm run test:unit\"",
    "test:setup": "npm run firebase:seed-emulator",
    "test:genkit": "node scripts/simple-genkit-test.js",
    "test:genkit:flow": "GENKIT_ENV=dev npm run build:ai && genkit flow:run runItemMatchEvaluation",
    "test:genkit:eval": "GENKIT_ENV=dev npm run build:ai && genkit eval:flow suggestMatchingItems",
    "build:status": "node scripts/startup-build-check.js",
    "commit-actions": "node scripts/workflows/commit-actions/commit-actions-simple-table.js",
    "commit-actions-plus": "node scripts/workflows/commit-actions/commit-actions-plus.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*": [
      "bash -c 'tsc --noEmit --skipLibCheck'"
    ]
  },
  "dependencies": {
    "@genkit-ai/googleai": "^1.8.0",
    "@genkit-ai/next": "^1.8.0",
    "@google/generative-ai": "^0.17.0",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
